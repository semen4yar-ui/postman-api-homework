    {
      "name": "Create List",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "let response = pm.response.json();\r",
              "\r",
              "pm.collectionVariables.set(\"list_id\", response.id);\r",
              "\r",
              "pm.test(\"List ID was created\", function () {\r",
              "    pm.expect(response.id).to.not.be.null;\r",
              "});\r",
              "const createListSchema = {\r",
              "    type: \"object\",\r",
              "    properties: {\r",
              "        id: {\r",
              "            type: \"string\"\r",
              "        },\r",
              "        name: {\r",
              "            type: \"string\"\r",
              "        },\r",
              "        orderindex: {\r",
              "            type: [\"string\", \"number\", \"null\"]\r",
              "        },\r",
              "        content: {\r",
              "            type: [\"string\", \"null\"]\r",
              "        }\r",
              "    },\r",
              "    required: [\"id\", \"name\"]\r",
              "};\r",
              "\r",
              "pm.test(\"Create List schema is valid\", function () {\r",
              "    pm.response.to.have.jsonSchema(createListSchema);\r",
              "});\r",
              "pm.test(\"Created list name is correct\", function () {\r",
              "    pm.expect(response.name).to.eql(pm.environment.get(\"random_list_name\"));\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const randomName = \"Test List \" + Math.floor(Math.random() * 10000);\r",
              "pm.environment.set(\"random_list_name\", randomName);"
