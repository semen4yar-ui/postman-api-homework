    {
      "name": "Get List",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "let response = pm.response.json();\r",
              "\r",
              "pm.test(\"Correct list returned\", function () {\r",
              "    pm.expect(response.id).to.exist;\r",
              "});\r",
              "\r",
              "const getListSchema = {\r",
              "    type: \"object\",\r",
              "    properties: {\r",
              "        id: {\r",
              "            type: \"string\"\r",
              "        },\r",
              "        name: {\r",
              "            type: \"string\"\r",
              "        },\r",
              "        orderindex: {\r",
              "            type: [\"string\", \"number\", \"null\"]\r",
              "        },\r",
              "        content: {\r",
              "            type: [\"string\", \"null\"]\r",
              "        }\r",
              "    },\r",
              "    required: [\"id\", \"name\"]\r",
              "};\r",
              "\r",
              "pm.test(\"Get List schema is valid\", function () {\r",
              "    pm.response.to.have.jsonSchema(getListSchema);\r",
              "});\r",
              "\r",
              "let listId = pm.environment.get(\"list_id\");\r",
              "\r",
              "if (listId) {\r",
              "    pm.sendRequest({\r",
              "        url: \"https://api.clickup.com/api/v2/list/\" + listId,\r",
              "        method: \"DELETE\",\r",
              "        header: {\r",
              "            \"Authorization\": pm.environment.get(\"token\"),\r",
              "            \"Content-Type\": \"application/json\"\r",
              "        }\r",
              "    }, function (err, res) {\r",
              "\r",
              "        if (err) {\r",
              "            console.log(\"Error while deleting list:\", err);\r",
              "            return;\r",
              "        }\r",
              "\r",
              "        console.log(\"Deleted list ID:\", listId);\r",
              "        pm.environment.unset(\"list_id\");\r",
              "    });\r",
              "} else {\r",
              "    console.log(\"list_id is empty, delete request was skipped\");\r",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "pm.sendRequest({\r",
              "    url: \"https://api.clickup.com/api/v2/folder/901211322607/list\",\r",
              "    method: \"POST\",\r",
              "    header: {\r",
              "        \"Authorization\": pm.environment.get(\"token\"),\r",
              "        \"Content-Type\": \"application/json\"\r",
              "    },\r",
              "    body: {\r",
              "        mode: \"raw\",\r",
              "        raw: JSON.stringify({\r",
              "            name: \"List from pre-request \" + Date.now()\r",
              "        })\r",
              "    }\r",
              "}, function (err, res) {\r",
              "    if (err) {\r",
              "        console.log(\"Error while creating list:\", err);\r",
              "        return;\r",
              "    }\r",
              "\r",
              "    console.log(\"Create list status:\", res.code);\r",
              "    console.log(\"Create list body:\", res.text());\r",
              "\r",
              "    if (res.code === 200) {\r",
              "        let response = res.json();\r",
              "\r",
              "        pm.environment.set(\"list_id\", response.id);\r",
              "\r",
              "        console.log(\"Created list ID:\", response.id);\r",
              "    } else {\r",
              "        console.log(\"List was not created\");\r",
              "    }\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
